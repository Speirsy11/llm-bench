# Hosted web application. Keep secrets empty in source control.
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
DATABASE_URL=

# Comma-separated GitHub logins allowed to curate sanitized public results.
LLMBENCH_ADMIN_GITHUB_LOGINS=

# Local/CI integration database. The reset command refuses names without "test".
TEST_DATABASE_URL=postgresql://llmbench:llmbench@localhost:5432/llmbench_test
